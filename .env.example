OPENAI_API_KEY=
OPENAI_MODEL_QUERY_PARSER=gpt-4o-mini
OPENAI_MODEL_RERANKER=gpt-4o-mini
OPENAI_MODEL_JUDGE=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_REASONING_EFFORT=low

# LLM layers (disable any to use deterministic fallbacks for that step)
ENABLE_OPENAI_QUERY_PARSER=true
ENABLE_OPENAI_RERANKER=true
ENABLE_OPENAI_COMBO_COMPOSER=true
COMBO_COMPOSER_MAX_ITEMS_PER_ROLE_FOR_LLM=18

# Dense retrieval: needs Postgres + pgvector, built catalog embeddings, and OPENAI_API_KEY
ENABLE_DENSE_RETRIEVAL_RERANK=false
DENSE_SHORTLIST_K_PER_ROLE=200
DENSE_RERANK_N_PER_ROLE=50

CATALOG_ITEMS_CSV=data/processed/catalog_items/catalog_items_demo.csv
CATALOG_ITEM_EMBEDDINGS_TABLE=catalog_item_embeddings
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fashion_bot
ITEMS_TABLE=items
ARTICLE_CHUNKS_TABLE=article_chunks
