# Copy this file to .env.
# For the normal local demo setup, most values below are already good defaults.
# Usually you only need to set OPENAI_API_KEY, and optionally change CATALOG_ITEMS_CSV
# or DATABASE_URL if your local setup is different.

# Set this in .env if you want OpenAI-powered recommendation steps or to build embeddings.
OPENAI_API_KEY=

# Recommended default models for local Track B runs.
OPENAI_MODEL_QUERY_PARSER=gpt-4o-mini
OPENAI_MODEL_RERANKER=gpt-4o-mini
OPENAI_MODEL_JUDGE=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_REASONING_EFFORT=low

# LLM layers.
# Leave these as-is for the standard setup.
# Turn any of them off only if you intentionally want deterministic fallbacks.
ENABLE_OPENAI_QUERY_PARSER=true
ENABLE_OPENAI_RERANKER=true
ENABLE_OPENAI_COMBO_COMPOSER=true
COMBO_COMPOSER_MAX_ITEMS_PER_ROLE_FOR_LLM=18

# Dense retrieval.
# Requires Docker: run `docker compose up -d` so Postgres + pgvector is reachable on DATABASE_URL.
# Keep false if you are not running Postgres (recommended API will still use sparse retrieval + LLMs).
# After DB is up, build embeddings once: python scripts/build_catalog_embeddings.py
ENABLE_DENSE_RETRIEVAL_RERANK=false
DENSE_SHORTLIST_K_PER_ROLE=200
DENSE_RERANK_N_PER_ROLE=50

# Catalog / database defaults for the provided local demo setup.
CATALOG_ITEMS_CSV=data/recommender/processed/catalog_items/catalog_items_demo.csv
CATALOG_ITEM_EMBEDDINGS_TABLE=catalog_item_embeddings
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fashion_bot
ITEMS_TABLE=items
ARTICLE_CHUNKS_TABLE=article_chunks
